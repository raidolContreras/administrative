# Copiar a .env y ajustar por instalación. NUNCA subir .env a git.

APP_NAME="Panel Administrativo"
# production | local
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=America/Mexico_City
# URL pública (https://midominio.com o https://midominio.com/sistema). Recomendado en
# producción: los enlaces de correo NO dependen del header Host (anti host-poisoning).
APP_URL=
# Cambiar al desplegar para invalidar cache de assets (o dejar vacío para usar la versión del core)
ASSET_VERSION=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Nombre de la cookie de sesión (único por instalación si conviven varias en un dominio)
SESSION_NAME=adm_session
# Minutos de inactividad antes de cerrar sesión
SESSION_IDLE_MINUTES=120
# auto = Secure solo bajo HTTPS | true | false
SESSION_SECURE=auto

# Remitente de correos (recuperación de contraseña), p. ej. no-responder@midominio.com.
# Vacío = no se envía nada; los correos quedan en storage/logs/mail.log (útil en desarrollo).
MAIL_FROM=
MAIL_FROM_NAME=
